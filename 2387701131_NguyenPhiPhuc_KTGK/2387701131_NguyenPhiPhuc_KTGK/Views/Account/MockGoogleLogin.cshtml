@{
    ViewData["Title"] = "Đăng nhập bằng Google (Mô phỏng)";
}

<div class="auth-container">
    <div class="auth-card" style="max-width: 450px; border-top: 4px solid #4285F4;">
        <div class="auth-header text-center mb-4">
            <div style="font-family: 'Product Sans', Arial, sans-serif; font-size: 32px; font-weight: bold; margin-bottom: 10px;">
                <span style="color: #4285F4;">G</span>
                <span style="color: #EA4335;">o</span>
                <span style="color: #FBBC05;">o</span>
                <span style="color: #4285F4;">g</span>
                <span style="color: #34A853;">l</span>
                <span style="color: #EA4335;">e</span>
            </div>
            <h4 class="fw-bold">Đăng nhập tài khoản</h4>
            <p class="text-muted small">Môi trường giả lập Google Sign-In để Test</p>
        </div>

        <div class="alert alert-info border-0 shadow-sm mb-4" style="background-color: #e8f0fe; border-left: 4px solid #1a73e8 !important;">
            <div class="d-flex">
                <div class="me-2">
                    <i class="fas fa-info-circle text-primary" style="font-size: 20px;"></i>
                </div>
                <div>
                    <h6 class="alert-heading fw-bold mb-1 text-primary" style="font-size: 14px;">Chế độ Giả lập (Testing Mode)</h6>
                    <p class="mb-0 text-dark" style="font-size: 12.5px; line-height: 1.5;">
                        Do <code>ClientId</code> chưa được cấu hình hoặc sử dụng giá trị mặc định, hệ thống tự động chuyển sang chế độ giả lập này để bạn dễ dàng test và chụp ảnh báo cáo mà không cần cấu hình Google Cloud Console.
                    </p>
                </div>
            </div>
        </div>

        <form asp-action="MockGoogleLogin" method="post">
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-floating mb-3">
                <input type="email" name="email" id="emailInput" class="form-control" placeholder="example@gmail.com" required value="test_student@gmail.com" />
                <label for="emailInput">Địa chỉ Email Google</label>
                <div class="form-text text-muted">Bất kỳ email hợp lệ nào (ví dụ: student@gmail.com)</div>
            </div>

            <div class="form-floating mb-4">
                <input type="text" name="name" id="nameInput" class="form-control" placeholder="Họ và tên" required value="Sinh Viên Thử Nghiệm" />
                <label for="nameInput">Họ và tên của bạn</label>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-2">
                <a asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" class="text-decoration-none fw-semibold" style="color: #1a73e8; font-size: 14px;">
                    Quay lại
                </a>
                <button type="submit" class="btn btn-primary px-4 py-2" style="background-color: #1a73e8; border-color: #1a73e8; font-weight: 500; font-size: 14px; border-radius: 4px;">
                    Tiếp tục
                </button>
            </div>
        </form>
    </div>
</div>
