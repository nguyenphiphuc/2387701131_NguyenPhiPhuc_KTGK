@model IEnumerable<_2387701131_NguyenPhiPhuc_KTGK.Models.Course>
@{
    ViewData["Title"] = "Quản lý học phần";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="page-title"><i class="fas fa-book"></i> Quản lý học phần</h1>
        <a asp-action="Create" class="btn btn-success btn-lg">
            <i class="fas fa-plus"></i> Thêm học phần
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-hover admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Hình ảnh</th>
                    <th>Tên học phần</th>
                    <th>Tín chỉ</th>
                    <th>Giảng viên</th>
                    <th>Danh mục</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var course in Model)
                {
                    <tr>
                        <td>@course.Id</td>
                        <td>
                            @if (!string.IsNullOrEmpty(course.Image))
                            {
                                <img src="@course.Image" alt="@course.Name" class="table-image" />
                            }
                            else
                            {
                                <span class="text-muted"><i class="fas fa-image"></i></span>
                            }
                        </td>
                        <td><strong>@course.Name</strong></td>
                        <td><span class="badge bg-info">@course.Credits</span></td>
                        <td>@course.Lecturer</td>
                        <td><span class="badge bg-secondary">@course.Category?.Name</span></td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@course.Id" class="btn btn-warning btn-sm">
                                <i class="fas fa-edit"></i> Sửa
                            </a>
                            <a asp-action="Delete" asp-route-id="@course.Id" class="btn btn-danger btn-sm">
                                <i class="fas fa-trash"></i> Xóa
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <a asp-action="Dashboard" class="btn btn-outline-primary"><i class="fas fa-arrow-left"></i> Quay lại Dashboard</a>
</div>
