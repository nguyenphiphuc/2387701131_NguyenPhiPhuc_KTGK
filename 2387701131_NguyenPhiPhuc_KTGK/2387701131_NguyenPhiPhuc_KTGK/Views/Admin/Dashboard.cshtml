@model _2387701131_NguyenPhiPhuc_KTGK.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard - Quản trị";
}

<div class="container mt-4">
    <h1 class="page-title"><i class="fas fa-tachometer-alt"></i> Dashboard Quản trị</h1>

    <!-- Stats Cards -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="stat-card stat-courses">
                <div class="stat-icon"><i class="fas fa-book"></i></div>
                <div class="stat-info">
                    <h3>@Model.TotalCourses</h3>
                    <p>Tổng số học phần</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card stat-students">
                <div class="stat-icon"><i class="fas fa-users"></i></div>
                <div class="stat-info">
                    <h3>@Model.TotalStudents</h3>
                    <p>Tổng số sinh viên</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card stat-enrollments">
                <div class="stat-icon"><i class="fas fa-clipboard-list"></i></div>
                <div class="stat-info">
                    <h3>@Model.TotalEnrollments</h3>
                    <p>Tổng số lượt đăng ký</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Category Distribution -->
        <div class="col-md-6 mb-4">
            <div class="dashboard-card">
                <h4><i class="fas fa-chart-pie"></i> Phân bổ theo danh mục</h4>
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Danh mục</th>
                            <th>Số học phần</th>
                            <th>Tỷ lệ</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cat in Model.CategoryStats)
                        {
                            var percent = Model.TotalCourses > 0 ? (cat.CourseCount * 100.0 / Model.TotalCourses) : 0;
                            <tr>
                                <td>@cat.CategoryName</td>
                                <td><span class="badge bg-primary">@cat.CourseCount</span></td>
                                <td>
                                    <div class="progress">
                                        <div class="progress-bar" style="width: @percent%">@percent.ToString("F0")%</div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Top Courses -->
        <div class="col-md-6 mb-4">
            <div class="dashboard-card">
                <h4><i class="fas fa-trophy"></i> Top học phần được đăng ký</h4>
                @if (Model.TopCourses.Any())
                {
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Học phần</th>
                                <th>Số lượt đăng ký</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ var rank = 1; }
                            @foreach (var course in Model.TopCourses)
                            {
                                <tr>
                                    <td>
                                        @if (rank == 1) { <span class="trophy gold"><i class="fas fa-trophy"></i></span> }
                                        else if (rank == 2) { <span class="trophy silver"><i class="fas fa-trophy"></i></span> }
                                        else if (rank == 3) { <span class="trophy bronze"><i class="fas fa-trophy"></i></span> }
                                        else { @rank }
                                    </td>
                                    <td>@course.CourseName</td>
                                    <td><span class="badge bg-success">@course.EnrollmentCount</span></td>
                                </tr>
                                rank++;
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted text-center">Chưa có lượt đăng ký nào.</p>
                }
            </div>
        </div>
    </div>

    <div class="text-center">
        <a asp-action="Courses" class="btn btn-primary btn-lg">
            <i class="fas fa-cog"></i> Quản lý học phần
        </a>
    </div>
</div>
